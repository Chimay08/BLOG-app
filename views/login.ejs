<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login – ChinMay BloGs</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body>

<div class="dm-fixed">
  <button id="dmToggle" class="dm-toggle" aria-label="Toggle dark mode" title="Toggle dark mode"></button>
</div>

<div class="split-container">

  <!-- LEFT -->
  <div class="left-panel">
    <div class="auth-card">

      <h1 class="logo-text">ChinMay BloGs</h1>
      <p class="subtitle">Welcome back! Sign in to continue.</p>

      <% if (error) { %>
        <div class="auth-error">
          <i class="bi bi-exclamation-circle"></i> <%= error %>
        </div>
      <% } %>

      <form action="/login" method="POST" class="auth-form">

        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" placeholder="you@example.com" required />
        </div>

        <div class="form-group">
          <label>Password</label>
          <input type="password" name="password" placeholder="••••••••" required />
        </div>

        <button type="submit" class="auth-btn">
          Login <i class="bi bi-arrow-right"></i>
        </button>

      </form>

      <div class="auth-divider"><span>or</span></div>

      <a href="/auth/google" class="google-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
          <path d="M15.545 6.558a9.4 9.4 0 0 1 .139 1.626c0 2.434-.87 4.492-2.384 5.885h.002C11.978 15.292 10.158 16 8 16A8 8 0 1 1 8 0a7.7 7.7 0 0 1 5.352 2.082l-2.284 2.284A4.35 4.35 0 0 0 8 3.166c-2.087 0-3.86 1.408-4.492 3.304a4.8 4.8 0 0 0 0 3.063h.003c.635 1.893 2.405 3.301 4.492 3.301 1.078 0 2.004-.276 2.722-.764h-.003a3.7 3.7 0 0 0 1.599-2.431H8v-3.08z"/>
        </svg>
        Continue with Google
      </a>

      <p class="auth-switch">Don't have an account? <a href="/register">Register here</a></p>

    </div>
  </div>

  <!-- RIGHT -->
  <div class="right-panel">
    <video class="bg-video" autoplay muted loop>
      <source src="/videos/2340-157269921 (1).mp4" type="video/mp4"/>
    </video>
  </div>

</div>


<script src="/js/darkmode.js"></script>
</body>
</html>
